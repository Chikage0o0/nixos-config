{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nixos": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-nixos"
      ]
    }
  },
  "tools": {
    "nixos": true
  },
  "permission": {
    "read": {
      "*": "allow",
      "ssh-keys/*": "deny",
      "*/ssh-keys/*": "deny",
      "secrets.yaml": "deny",
      "*/secrets.yaml": "deny"
    }
  }
}
