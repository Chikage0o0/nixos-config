{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["uvx", "mcp-nixos"]
    }
  },
  "tools": {
    "nixos": true
  },
  "permission": {
    "read": {
      "*": "allow",
      "vars.nix": "deny",
      "*/vars.nix": "deny",
      "ssh-keys/*": "deny",
      "*/ssh-keys/*": "deny"
    }
  }
}
